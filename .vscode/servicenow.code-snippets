{
  // ═══════════════════════════════════════════════════════════════════════════
  // SESSION SETUP
  // ═══════════════════════════════════════════════════════════════════════════

  "SN: Session Setup": {
    "prefix": ["sn-setup", "snsetup"],
    "body": [
      "// Set application scope",
      "SN-Set-Current-Application({ app_sys_id: \"${1:app_sys_id}\" })",
      "",
      "// Set update set",
      "SN-Set-Update-Set({ update_set_sys_id: \"${2:update_set_sys_id}\" })",
      "",
      "// Verify context",
      "SN-Get-Current-Update-Set()"
    ],
    "description": "ServiceNow session setup - always start here"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // DISCOVERY COMMANDS
  // ═══════════════════════════════════════════════════════════════════════════

  "SN: Query Table": {
    "prefix": ["sn-query", "snquery"],
    "body": [
      "SN-Query-Table({",
      "  table_name: \"${1:table_name}\",",
      "  query: \"${2:active=true}\",",
      "  fields: \"${3:sys_id,name}\"",
      "})"
    ],
    "description": "Query ServiceNow table"
  },

  "SN: Discover Schema": {
    "prefix": ["sn-schema", "snschema"],
    "body": [
      "SN-Discover-Table-Schema({",
      "  table_name: \"${1:table_name}\",",
      "  include_relationships: true,",
      "  include_choices: true",
      "})"
    ],
    "description": "Discover full table schema"
  },

  "SN: Get Record": {
    "prefix": ["sn-get", "snget"],
    "body": [
      "SN-Get-Record({",
      "  table_name: \"${1:table_name}\",",
      "  sys_id: \"${2:sys_id}\"",
      "})"
    ],
    "description": "Get single record by sys_id"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // CREATE COMMANDS
  // ═══════════════════════════════════════════════════════════════════════════

  "SN: Create Record": {
    "prefix": ["sn-create", "sncreate"],
    "body": [
      "SN-Create-Record({",
      "  table_name: \"${1:table_name}\",",
      "  data: {",
      "    ${2:field}: \"${3:value}\"",
      "  }",
      "})"
    ],
    "description": "Create a new record"
  },

  "SN: Create Table": {
    "prefix": ["sn-create-table", "sntable"],
    "body": [
      "SN-Create-Record({",
      "  table_name: \"sys_db_object\",",
      "  data: {",
      "    name: \"u_${1:table_name}\",",
      "    label: \"${2:Table Label}\",",
      "    super_class: \"${3|task,cmdb_ci,|}\"",
      "    is_extendable: true,",
      "    create_module: true",
      "  }",
      "})"
    ],
    "description": "Create a new ServiceNow table"
  },

  "SN: Create Field - String": {
    "prefix": ["sn-field-string", "snfieldstr"],
    "body": [
      "SN-Create-Record({",
      "  table_name: \"sys_dictionary\",",
      "  data: {",
      "    name: \"${1:table_name}\",",
      "    element: \"u_${2:field_name}\",",
      "    column_label: \"${3:Field Label}\",",
      "    internal_type: \"string\",",
      "    max_length: ${4:255},",
      "    mandatory: ${5|false,true|},",
      "    active: true",
      "  }",
      "})"
    ],
    "description": "Create a string field"
  },

  "SN: Create Field - Reference": {
    "prefix": ["sn-field-ref", "snfieldref"],
    "body": [
      "SN-Create-Record({",
      "  table_name: \"sys_dictionary\",",
      "  data: {",
      "    name: \"${1:table_name}\",",
      "    element: \"u_${2:field_name}\",",
      "    column_label: \"${3:Field Label}\",",
      "    internal_type: \"reference\",",
      "    reference: \"${4:target_table}\",",
      "    mandatory: ${5|false,true|},",
      "    active: true",
      "  }",
      "})"
    ],
    "description": "Create a reference field"
  },

  "SN: Create Field - Boolean": {
    "prefix": ["sn-field-bool", "snfieldbool"],
    "body": [
      "SN-Create-Record({",
      "  table_name: \"sys_dictionary\",",
      "  data: {",
      "    name: \"${1:table_name}\",",
      "    element: \"u_${2:field_name}\",",
      "    column_label: \"${3:Field Label}\",",
      "    internal_type: \"boolean\",",
      "    default_value: \"${4|true,false|}\",",
      "    active: true",
      "  }",
      "})"
    ],
    "description": "Create a boolean field"
  },

  "SN: Create Choice": {
    "prefix": ["sn-choice", "snchoice"],
    "body": [
      "SN-Create-Record({",
      "  table_name: \"sys_choice\",",
      "  data: {",
      "    name: \"${1:table_name}\",",
      "    element: \"${2:field_name}\",",
      "    value: \"${3:value}\",",
      "    label: \"${4:Label}\",",
      "    sequence: ${5:100}",
      "  }",
      "})"
    ],
    "description": "Create a choice value"
  },

  "SN: Create Script Include": {
    "prefix": ["sn-script-include", "snsi"],
    "body": [
      "SN-Create-Record({",
      "  table_name: \"sys_script_include\",",
      "  data: {",
      "    name: \"${1:ScriptName}\",",
      "    api_name: \"global.${1:ScriptName}\",",
      "    client_callable: ${2|false,true|},",
      "    active: true,",
      "    description: \"${3:Description}\",",
      "    script: `var ${1:ScriptName} = Class.create();",
      "${1:ScriptName}.prototype = {",
      "    initialize: function() {",
      "        this.LOG_SOURCE = '${1:ScriptName}';",
      "    },",
      "",
      "    ${4:methodName}: function(${5:param}) {",
      "        try {",
      "            // Implementation",
      "            return { success: true, data: null };",
      "        } catch (e) {",
      "            gs.error(this.LOG_SOURCE + '.${4:methodName}: ' + e.message);",
      "            return { success: false, error: e.message };",
      "        }",
      "    },",
      "",
      "    type: '${1:ScriptName}'",
      "};`",
      "  }",
      "})"
    ],
    "description": "Create a Script Include"
  },

  "SN: Create Business Rule": {
    "prefix": ["sn-business-rule", "snbr"],
    "body": [
      "SN-Create-Record({",
      "  table_name: \"sys_script\",",
      "  data: {",
      "    name: \"${1:Rule Name}\",",
      "    collection: \"${2:table_name}\",",
      "    when: \"${3|after,before,async|}\",",
      "    action_insert: ${4|true,false|},",
      "    action_update: ${5|true,false|},",
      "    action_delete: ${6|false,true|},",
      "    action_query: false,",
      "    order: ${7:100},",
      "    active: true,",
      "    script: `(function executeRule(current, previous) {",
      "    ${8:// Exit early if not relevant}",
      "    ${9:if (!current.field.changes()) return;}",
      "",
      "    try {",
      "        // Implementation",
      "        $0",
      "    } catch (e) {",
      "        gs.error('BR-${1:Rule Name}: ' + e.message);",
      "    }",
      "})(current, previous);`",
      "  }",
      "})"
    ],
    "description": "Create a Business Rule"
  },

  "SN: Create ACL": {
    "prefix": ["sn-acl", "snacl"],
    "body": [
      "SN-Create-Record({",
      "  table_name: \"sys_security_acl\",",
      "  data: {",
      "    name: \"${1:table_name}\",",
      "    operation: \"${2|read,write,create,delete|}\",",
      "    admin_overrides: true,",
      "    active: true,",
      "    description: \"${3:ACL description}\"",
      "  }",
      "})"
    ],
    "description": "Create an ACL"
  },

  // ═══════════════════════════════════════════════════════════════════════════
