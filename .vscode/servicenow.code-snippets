  "SN: Update Record": {
    "prefix": ["sn-update", "snupdate"],
    "body": [
      "SN-Update-Record({",
      "  table_name: \"${1:table_name}\",",
      "  sys_id: \"${2:sys_id}\",",
      "  data: {",
      "    ${3:field}: \"${4:value}\"",
      "  }",
      "})"
    ],
    "description": "Update an existing record"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // TESTING & VALIDATION
  // ═══════════════════════════════════════════════════════════════════════════

  "SN: Execute Background Script": {
    "prefix": ["sn-script", "snscript", "sn-bg"],
    "body": [
      "SN-Execute-Background-Script({",
      "  script: `",
      "    ${1:// Your script here}",
      "    $0",
      "  `,",
      "  execution_method: \"trigger\"",
      "})"
    ],
    "description": "Execute a background script"
  },

  "SN: Unit Test Template": {
    "prefix": ["sn-test", "sntest"],
    "body": [
      "SN-Execute-Background-Script({",
      "  script: `",
      "    var T = {",
      "      results: [],",
      "      assertEqual: function(a, e, m) {",
      "        var p = a === e;",
      "        this.results.push({t:m, p:p, a:a, e:e});",
      "        return p;",
      "      },",
      "      assertTrue: function(c, m) {",
      "        this.results.push({t:m, p:c, a:c, e:true});",
      "        return c;",
      "      },",
      "      report: function() {",
      "        var pass=0, fail=0;",
      "        this.results.forEach(function(r) {",
      "          if(r.p) pass++; else fail++;",
      "          gs.info((r.p?'PASS':'FAIL')+': '+r.t);",
      "          if(!r.p) gs.info('  Expected:'+r.e+' Got:'+r.a);",
      "        });",
      "        gs.info('=== '+pass+' passed, '+fail+' failed ===');",
      "        return fail===0;",
      "      }",
      "    };",
      "",
      "    // TEST: ${1:Test description}",
      "    (function() {",
      "      ${2:// Your test here}",
      "      T.assertTrue(${3:condition}, '${4:assertion message}');",
      "    })();",
      "",
      "    T.report();",
      "  `,",
      "  execution_method: \"trigger\"",
      "})"
    ],
    "description": "Unit test template with test runner"
  },

  "SN: Verify Update Set": {
    "prefix": ["sn-verify", "snverify"],
    "body": [
      "SN-Query-Table({",
      "  table_name: \"sys_update_xml\",",
      "  query: \"update_set=${1:update_set_sys_id}^sys_created_onONToday@javascript:gs.beginningOfToday()@javascript:gs.endOfToday()\",",
      "  fields: \"name,type,action,target_name\"",
      "})"
    ],
    "description": "Verify update set contents"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // UPDATE SET MANAGEMENT
  // ═══════════════════════════════════════════════════════════════════════════

  "SN: List Update Sets": {
    "prefix": ["sn-list-us", "snlistus"],
    "body": [
      "SN-List-Update-Sets({",
      "  query: \"state=in progress\"",
      "})"
    ],
    "description": "List in-progress update sets"
  },

  "SN: Move Records to Update Set": {
    "prefix": ["sn-move", "snmove"],
    "body": [
      "SN-Move-Records-To-Update-Set({",
      "  update_set_id: \"${1:correct_update_set_sys_id}\",",
      "  source_update_set: \"${2:Default}\"",
      "})"
    ],
    "description": "Move records to correct update set"
  },

  // ═══════════════════════════════════════════════════════════════════════════
  // GLIDE SCRIPT PATTERNS
  // ═══════════════════════════════════════════════════════════════════════════

  "Glide: GlideRecord Query": {
    "prefix": ["gr-query", "grquery"],
    "body": [
      "var gr = new GlideRecord('${1:table_name}');",
      "gr.addQuery('${2:field}', '${3:value}');",
      "gr.query();",
      "while (gr.next()) {",
      "    ${0:// Process record}",
      "}"
    ],
    "description": "GlideRecord query pattern"
  },

  "Glide: GlideRecord Get": {
    "prefix": ["gr-get", "grget"],
    "body": [
      "var gr = new GlideRecord('${1:table_name}');",
      "if (gr.get('${2:sys_id}')) {",
      "    ${0:// Record found}",
      "}"
    ],
    "description": "GlideRecord get by sys_id"
  },

  "Glide: GlideRecord Insert": {
    "prefix": ["gr-insert", "grinsert"],
    "body": [
      "var gr = new GlideRecord('${1:table_name}');",
      "gr.initialize();",
      "gr.${2:field} = '${3:value}';",
      "var sysId = gr.insert();",
      "gs.info('Created: ' + sysId);"
    ],
    "description": "GlideRecord insert pattern"
  },

  "Glide: GlideAggregate Count": {
    "prefix": ["ga-count", "gacount"],
    "body": [
      "var ga = new GlideAggregate('${1:table_name}');",
      "ga.addQuery('${2:field}', '${3:value}');",
      "ga.addAggregate('COUNT');",
      "ga.query();",
      "var count = 0;",
      "if (ga.next()) {",
      "    count = ga.getAggregate('COUNT');",
      "}",
      "gs.info('Count: ' + count);"
    ],
    "description": "GlideAggregate count pattern"
  },

